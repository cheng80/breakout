{
  "name": "swipe-brick-breaker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:ultimate-fixture": "vite --host 0.0.0.0 --mode ultimate-fixture",
    "dev:stage-fixture": "vite --host 0.0.0.0 --mode stage-fixture",
    "test": "vitest",
    "build": "tsc --noEmit && vite build",
    "build:ultimate-fixture": "tsc --noEmit && vite build --mode ultimate-fixture",
    "build:stage-fixture": "tsc --noEmit && vite build --mode stage-fixture",
    "audio:plan": "node scripts/generate-audio.mjs",
    "audio:generate": "node scripts/generate-audio.mjs --generate"
  },
  "dependencies": {
    "pixi.js": "^8.12.0"
  },
  "devDependencies": {
    "lucide-static": "^1.25.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
